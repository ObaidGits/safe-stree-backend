# Server Configuration
PORT=8000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
DB_NAME=SafeStree

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# JWT Tokens
ACCESS_TOKEN_SECRET=your_access_token_secret_here_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_min_32_chars
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

# CCTV/ML Backend API Key
# Must match the key configured in backend/ml/.env
CCTV_API_KEY=your_secure_api_key_here

# Internal ML service auth token (used by /api/v1/cctv/internal)
INTERNAL_ML_SERVICE_TOKEN=your_internal_ml_service_token_here

# OpenCage Geocoding API Key (for reverse geocoding)
# Get your key at: https://opencagedata.com/
OPENCAGE_API_KEY=your_opencage_api_key_here

# For Production
# NODE_ENV=production
# CORS_ORIGIN=https://yourfrontend.com
