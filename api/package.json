{
  "name": "server",
  "version": "2.0.0",
  "description": "A women safety app with enhanced backend",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon -r dotenv/config app.js",
    "start": "node app.js",
    "test": "NODE_ENV=test jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "seed": "node scripts/seed.js",
    "clean-logs": "rm -rf logs/*",
    "docker:build": "docker build -t safestree-backend .",
    "docker:run": "docker run -p 8000:8000 safestree-backend",
    "docker:dev": "docker-compose up --build"
  },
  "keywords": [
    "javascript",
    "backend",
    "women-safety",
    "sos",
    "emergency"
  ],
  "author": "SafeStree",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.0.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.0",
    "mongoose-aggregate-paginate-v2": "^1.1.4",
    "multer": "^1.4.5-lts.2",
    "socket.io": "^4.8.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "optionalDependencies": {
    "sharp": "^0.33.5"
  }
}
